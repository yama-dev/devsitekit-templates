{
  "name": "@yama-dev/devsitekit-project",
  "version": "[[devsitekitVersion]]",
  "private": true,
  "scripts": {
    "serve": "devsitekit serve",
    "build": "devsitekit build",
    "preview": "devsitekit preview",
    "clean": "devsitekit clean",
    "doctor": "devsitekit doctor --project"
  },
  "volta": {
    "node": "24.13.0"
  },
  "engines": {
    "node": ">=24"
  },
  "browserslist": {
    "development": [
      "Chrome >= 90",
      "Edge >= 90",
      "Firefox ESR",
      "Safari >= 13",
      "iOS >= 13",
      "not IE 11"
    ],
    "production": [
      "Chrome >= 90",
      "Edge >= 90",
      "Firefox ESR",
      "Safari >= 13",
      "iOS >= 13",
      "not IE 11"
    ]
  },
  "devDependencies": {
    "[[devPackageName]]": "[[devPackageVersion]]"
  }
}
