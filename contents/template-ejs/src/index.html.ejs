<!DOCTYPE html>
<html lang="ja">
<head prefix="og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article: http://ogp.me/ns/article#">
  <%- include('./_partials/head.html.ejs') %>
  <link rel="stylesheet" href="./assets/css/style.css">
</head>
<body>
  <%- include('./_partials/header.html.ejs') %>

  <main>
    <article>
      <section class="l-section">
        <h2>H2</h2>
        <p>Start building your page from this EJS template.</p>
      </section>
    </article>

    <section class="l-section">
      <h2>Share</h2>
      <ul class="p-snslist">
        <li class="p-snslist__item"><a href="https://twitter.com/share?url=[url]&amp;text=[text]&amp;hashtags=[hashtags]" target="_blank" rel="noopener">Twitter</a></li>
        <li class="p-snslist__item"><a href="https://www.facebook.com/sharer.php?u=[url]" target="_blank" rel="noopener">Facebook</a></li>
        <li class="p-snslist__item"><a href="https://social-plugins.line.me/lineit/share?url=[url]" target="_blank" rel="noopener">LINE</a></li>
        <li class="p-snslist__item"><a href="https://b.hatena.ne.jp/add?url=[url]" target="_blank" rel="noopener">Hatena Bookmark</a></li>
      </ul>
    </section>
  </main>

  <%- include('./_partials/footer.html.ejs') %>

  <script src="./assets/js/site.js"></script>
</body>
</html>
